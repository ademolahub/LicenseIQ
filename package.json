{
  "name": "licenseiq",
  "version": "1.0.0",
  "private": true,
  "description": "Microsoft 365 License Optimization & Tenant Health Assessment Tool",
  "workspaces": [
    "frontend",
    "backend",
    "worker"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:worker": "npm run start --workspace=worker",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
